# Generation LLM (provider read by oasis/llm.py)
GEN_PROVIDER=anthropic
GEN_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...   # only needed if GEN_PROVIDER=openai

# Neo4j (matches docker run in README)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=oasisdemo

# Chroma persistent dir (separate store from the graph)
CHROMA_DIR=.chroma

# Optional graph visualization (requires the viz extra: uv sync --extra viz)
ENABLE_GRAPH_VIZ=false
